---
// TrackAccordion.astro
// Drop this into your Starlight content or components directory
---

<div class="tracks-section">
  <h2 class="tracks-heading">Choose Your Track</h2>

  <details class="track-accordion" name="tracks">
    <summary class="track-summary">
      <span class="track-icon">🚀</span>
      <span class="track-title">Onboarding Track</span>
      <span class="track-tag">Ready to go</span>
      <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </summary>
    <div class="track-body">
      <p>Your idea already meets project requirements. You're ready to <strong>pitch your idea</strong> and <strong>form a team</strong>.</p>
      <a href="/onboardingtrack" class="track-cta">Learn About the Onboarding</a>
    </div>
  </details>

  <details class="track-accordion" name="tracks">
    <summary class="track-summary">
      <span class="track-icon">🌱</span>
      <span class="track-title">Incubator Track</span>
      <span class="track-tag track-tag--incubator">Needs development</span>
      <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </summary>
    <div class="track-body">
      <p>Your idea is civic-minded and open source, but still needs work. Maybe you don't have a community partner yet or the scope isn't defined. We'll support you in getting there.</p>
      <a href="/incubatortrack" class="track-cta track-cta--incubator">Learn About the Incubator →</a>
    </div>
  </details>
</div>

<style>
  .tracks-section {
    margin: 2rem 0;
    max-width: 720px;
  }

  .tracks-heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--sl-color-text);
  }

  /* --- Accordion shell --- */
  .track-accordion {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .track-accordion[open] {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: var(--sl-color-accent);
  }

  /* --- Summary row --- */
  .track-summary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: var(--sl-color-bg-sidebar);
    transition: background 0.15s ease;
  }

  .track-summary::-webkit-details-marker { display: none; }

  .track-summary:hover {
    background: var(--sl-color-gray-7, #f5f5f5);
  }

  .track-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .track-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sl-color-text);
    flex: 1;
  }

  .track-tag {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    background: var(--sl-color-accent-low, #3a99f1);
    color: var(--sl-color-accent, #217de7);
  }

  .track-tag--incubator {
    background: #fff4e0;
    color: #9a6200;
  }

  .chevron {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--sl-color-gray-3);
    transition: transform 0.25s ease;
  }

  .track-accordion[open] .chevron {
    transform: rotate(180deg);
  }

  /* --- Body --- */
  .track-body {
    padding: 1.25rem 1.5rem 1.5rem;
    border-top: 1px solid var(--sl-color-gray-6);
    background: var(--sl-color-bg);
  }

  .track-body p {
    margin: 0 0 0.75rem;
    color: var(--sl-color-text);
    line-height: 1.6;
  }

  .track-body ul {
    margin: 0.5rem 0 1.25rem 0;
    padding-left: 1.25rem;
    color: var(--sl-color-text);
    line-height: 1.8;
  }

  .track-body ul li {
    list-style: none;
    padding-left: 0;
  }

  /* --- CTA link --- */
  .track-cta {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--sl-color-accent);
    color: var(--sl-color-white, #fff);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .track-cta:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .track-cta--incubator {
    background: #e8a000;
  }
</style>